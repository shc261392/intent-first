# ── HTTP helpers ──────────────────────────────────────────────

def _fetch_text(url: str, timeout: int = 10) -> str:
    req = Request(url, headers={"User-Agent": f"intent-first/{VERSION}"})
    try:
        with urlopen(req, timeout=timeout) as resp:
            return resp.read().decode("utf-8", errors="replace")
    except Exception:
        return ""


def _download(url: str, dest: Path, timeout: int = 30) -> bool:
    req = Request(url, headers={"User-Agent": f"intent-first/{VERSION}"})
    try:
        with urlopen(req, timeout=timeout) as resp:
            dest.write_bytes(resp.read())
        return True
    except Exception as exc:
        warn(f"Download failed: {url} \u2014 {exc}")
        return False


# ── Version check ─────────────────────────────────────────────

def check_latest_version() -> None:
    now = int(time.time())
    cached_version, cached_time = "", 0
    if VERSION_CACHE.exists():
        try:
            parts = VERSION_CACHE.read_text().strip().split(":", 1)
            cached_version = parts[0]
            cached_time = int(parts[1]) if len(parts) > 1 else 0
        except Exception:
            pass

    if (now - cached_time) < VERSION_CHECK_TTL and cached_version:
        latest = cached_version
    else:
        text = _fetch_text(f"https://api.github.com/repos/{REPO}/releases/latest")
        latest = ""
        if text:
            try:
                latest = json.loads(text).get("tag_name", "")
            except (json.JSONDecodeError, AttributeError):
                pass
        if latest:
            INTENT_FIRST_HOME.mkdir(parents=True, exist_ok=True)
            VERSION_CACHE.write_text(f"{latest}:{now}")

    current = f"v{VERSION}"
    if latest and latest not in (current, VERSION):
        print(f"{YELLOW}\u26a1 New version available: {latest} (you have {current}){RESET}", file=sys.stderr)
        print(f"   Run: {BOLD}intent-first upgrade{RESET}", file=sys.stderr)
        print("", file=sys.stderr)


