# Valid fields for each stage in status.yml
_STAGE_FIELDS: dict[str, list[str]] = {
    "intent":     ["status", "locked_at"],
    "spec":       ["status", "approved_by", "approved_at", "locked_at"],
    "plan":       ["status", "derived_from", "approved_by", "approved_at", "locked_at"],
    "execution":  ["status", "started_at", "completed_at", "locked_at"],
    "artifacts":  ["status", "completed_at", "locked_at"],
}


def cmd_status_update(args: list[str]) -> None:
    """Update a field in status.yml for a workflow stage.
    
    Usage: intent-first status-update <ID> <STAGE> --<FIELD> <VALUE>
    
    Examples:
      intent-first status-update 1 spec --status approved
      intent-first status-update 1 spec --approved-by "Alice"
      intent-first status-update 1 execution --status in_progress
    """
    if len(args) < 4:
        print("Usage: intent-first status-update <ID> <STAGE> --<FIELD> <VALUE>")
        print()
        print("Examples:")
        print("  intent-first status-update 1 spec --status approved")
        print("  intent-first status-update 1 spec --approved-by \"Alice\"")
        print("  intent-first status-update 1 execution --started-at \"2026-03-15T14:30:00Z\"")
        sys.exit(1)
    
    wid = args[0]
    stage_input = args[1]
    
    validate_workflow_id(wid)
    
    stage_key = resolve_stage_key(stage_input)
    if not stage_key:
        print(f"\u274c Unknown stage: {stage_input}")
        print("   Valid: intent, spec, plan, execution, artifacts (or 1-5)")
        sys.exit(1)
    
    # Parse --field value pairs
    updates: dict[str, str] = {}
    i = 2
    while i < len(args):
        if args[i].startswith("--"):
            field_name = args[i][2:]  # Remove "--"
            # Convert hyphens to underscores (e.g., "approved-by" → "approved_by")
            field_name = field_name.replace("-", "_")
            
            if i + 1 >= len(args):
                print(f"\u274c Missing value for --{field_name}")
                sys.exit(1)
            
            updates[field_name] = args[i + 1]
            i += 2
        else:
            print(f"\u274c Invalid argument: {args[i]}")
            print("   All updates must be in the form: --<field> <value>")
            sys.exit(1)
    
    if not updates:
        print("\u274c No fields to update")
        sys.exit(1)
    
    # Validate all fields exist for this stage
    valid_fields = _STAGE_FIELDS.get(stage_key, [])
    for field in updates:
        if field not in valid_fields:
            print(f"\u274c Invalid field for stage '{stage_key}': {field}")
            print(f"   Valid fields: {', '.join(valid_fields)}")
            sys.exit(1)
    
    # Update status.yml
    status_file = WORKFLOW_DIR / wid / "status.yml"
    if not status_file.is_file():
        print(f"\u274c Workflow not found: {WORKFLOW_DIR / wid}")
        sys.exit(1)
    
    # If updating timestamp fields, auto-fill current UTC time if not provided
    if "asked_at" in updates and updates["asked_at"] == "auto":
        updates["asked_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    if "approved_at" in updates and updates["approved_at"] == "auto":
        updates["approved_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    if "locked_at" in updates and updates["locked_at"] == "auto":
        updates["locked_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    if "started_at" in updates and updates["started_at"] == "auto":
        updates["started_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    if "completed_at" in updates and updates["completed_at"] == "auto":
        updates["completed_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    
    # Apply all updates
    for field, value in updates.items():
        update_stage_field(status_file, stage_key, field, value)
        print(f"  {stage_key}.{field} = {value}")
    
    print(f"\u2705 Updated {stage_key} in status.yml")


# ── cmd_phase_update ──────────────────────────────────────────

def cmd_phase_update(args: list[str]) -> None:
    """Update phase status within a stage.
    
    Usage: intent-first phase-update <ID> <STAGE> <PHASE> --status <STATUS> [--started-at auto] [--completed-at auto]
    """
    if len(args) < 5:
        print("Usage: intent-first phase-update <ID> <STAGE> <PHASE> --status <STATUS>")
        sys.exit(1)

    wid, stage_input, phase_name = args[0], args[1], args[2]
    validate_workflow_id(wid)

    stage_key = resolve_stage_key(stage_input)
    if not stage_key:
        print(f"\u274c Unknown stage: {stage_input}")
        sys.exit(1)

    # Validate phase exists for this stage
    valid_phases = STAGE_PHASES.get(stage_key, [])
    if phase_name not in valid_phases:
        print(f"\u274c Unknown phase '{phase_name}' for stage '{stage_key}'")
        print(f"   Valid phases: {', '.join(valid_phases)}")
        sys.exit(1)

    # Parse --field value pairs
    updates: dict[str, str] = {}
    i = 3
    while i < len(args):
        if args[i].startswith("--"):
            field_name = args[i][2:].replace("-", "_")
            if i + 1 >= len(args):
                print(f"\u274c Missing value for --{field_name}")
                sys.exit(1)
            updates[field_name] = args[i + 1]
            i += 2
        else:
            i += 1

    if "status" not in updates:
        print("\u274c --status is required")
        sys.exit(1)

    valid_statuses = ("pending", "in_progress", "complete", "skipped")
    if updates["status"] not in valid_statuses:
        print(f"\u274c Invalid status: {updates['status']}")
        print(f"   Valid: {', '.join(valid_statuses)}")
        sys.exit(1)

    status_file = WORKFLOW_DIR / wid / "status.yml"
    if not status_file.is_file():
        print(f"\u274c Workflow not found: {WORKFLOW_DIR / wid}")
        sys.exit(1)

    # Auto-fill timestamps
    ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    for tf in ("started_at", "completed_at"):
        if tf in updates and updates[tf] == "auto":
            updates[tf] = ts

    for field, value in updates.items():
        _update_phase_field(status_file, stage_key, phase_name, field, value)

    # Also update current_phase on the stage
    update_stage_field(status_file, stage_key, "current_phase", phase_name)

    print(f"\u2705 {stage_key}/{phase_name}: status={updates['status']}")


