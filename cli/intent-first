def cmd_init(args: list[str]) -> None:
    tool = "auto"
    i = 0
    while i < len(args):
        if args[i] == "--tool" and i + 1 < len(args):
            tool = args[i + 1]; i += 2
        else:
            tool = args[i]; i += 1

    print()
    print(f"{BOLD}Initializing Intent-First in this project...{RESET}")
    print()

    Path(".intent-first").mkdir(exist_ok=True)

    global_rules = INTENT_FIRST_HOME / "rules.md"
    if global_rules.is_file():
        dest = Path(".intent-first/rules.md")
        # Check if source and destination are the same (e.g., via symlink)
        if global_rules.resolve() != dest.resolve():
            shutil.copy2(global_rules, dest)
            info("Created .intent-first/rules.md")
        else:
            info(".intent-first/rules.md already linked to global rules (skipped)")
    else:
        warn(f"Global rules not found at {global_rules}")
        print("  Re-run the installer, then try again:")
        print(f"    curl -fsSL https://raw.githubusercontent.com/{REPO}/main/install.sh | bash")
        sys.exit(1)

    gitignore = Path(".gitignore")
    marker = ".intent-first/workflows/"
    if gitignore.is_file():
        if marker not in gitignore.read_text():
            with gitignore.open("a") as f:
                f.write(f"\n# Intent-First workflow data (ephemeral \u2014 do not commit)\n{marker}\n")
            info("Added .intent-first/workflows/ to .gitignore")
        else:
            info(".gitignore already covers .intent-first/workflows/ (skipped)")
    else:
        gitignore.write_text(f"# Intent-First workflow data (ephemeral \u2014 do not commit)\n{marker}\n")
        info("Created .gitignore with .intent-first/workflows/")

    if tool == "auto":
        tools = []
        if Path(".github").is_dir() or Path(".github/copilot-instructions.md").is_file():
            tools.append("copilot")
        if Path(".cursor").is_dir() or Path(".cursorrules").is_file():
            tools.append("cursor")
        if Path("CLAUDE.md").is_file():
            tools.append("claude")
        if Path(".windsurfrules").is_file():
            tools.append("windsurf")
        if Path(".aider.conf.yml").is_file() or Path(".aiderignore").is_file():
            tools.append("aider")
        if Path(".clinerules").is_file() or Path(".cline").is_dir():
            tools.append("cline")
        if not tools:
            tools = _ask_tool_interactive()
    else:
        tools = [tool]

    one_liner = "For the Intent-First Agentic Workflow, see `.intent-first/rules.md`."
    for t in tools:
        if t in _TOOL_FILES:
            _init_rules_oneliner(_TOOL_FILES[t], one_liner)

    step("Installing prompts and agents...")
    if not _install_prompts_and_agents(tools):
        print()
        warn("Failed to install prompts and agents.")
        warn("Re-run after checking your internet connection: intent-first init")
        sys.exit(1)

    print()
    print(f"{GREEN}\u2705 Intent-First initialized!{RESET}")
    print()
    print("  \U0001f4cb Next steps:")
    print("     1. Commit .intent-first/rules.md (your project-local workflow ruleset)")
    print("     2. Run: intent-first new")
    print("     3. Tell your AI agent: /wf-spec 1")
    print()
    print("  \U0001f4d6 For workflow documentation, see .intent-first/rules.md")


