def _status_all() -> None:
    """Show all workflows with relationships."""
    if not WORKFLOW_DIR.is_dir():
        print("No workflows yet. Run: intent-first new")
        return

    workflows = _sorted_workflows()
    if not workflows:
        print("No workflows found.")
        return

    print(f"{'ID':<15} {'TITLE':<30} {'STAGE':<15} PARENT")
    print(f"{'---':<15} {'---':<30} {'---':<15} ---")

    for d in workflows:
        wid = d.name
        title = "(untitled)"
        intent_file = d / "s1_intent.md"
        if intent_file.is_file():
            for line in intent_file.read_text().splitlines():
                m = re.match(r"^# Intent:\s*(.*)", line)
                if m:
                    title = m.group(1).strip()
                    break

        status_file = d / "status.yml"
        display_status = "\U0001f4a1 intent"
        parent = ""
        if status_file.is_file():
            a = get_stage_status(status_file, "artifacts")
            e = get_stage_status(status_file, "execution")
            p = get_stage_status(status_file, "plan")
            s = get_stage_status(status_file, "spec")
            if a in ("complete", "locked"):
                display_status = "\u2705 complete"
            elif e == "in_progress":
                display_status = "\u2699\ufe0f  executing"
            elif p in ("locked", "approved"):
                display_status = "\U0001f4cb planned"
            elif s in ("locked", "approved"):
                display_status = "\U0001f4d0 specified"
            parent = _read_top_level_field(status_file, "parent_workflow")

        parent_str = f"\u2190 {parent}" if parent else ""
        print(f"{wid:<15} {title[:30]:<30} {display_status:<15} {parent_str}")


def _status_single(wid: str) -> None:
    """Detailed status of one workflow."""
    wdir = WORKFLOW_DIR / wid
    if not wdir.is_dir():
        print(f"\u274c Workflow not found: {wdir}")
        sys.exit(1)

    status_file = wdir / "status.yml"
    title = "(untitled)"
    intent_file = wdir / "s1_intent.md"
    if intent_file.is_file():
        for line in intent_file.read_text().splitlines():
            m = re.match(r"^# Intent:\s*(.*)", line)
            if m:
                title = m.group(1).strip()
                break

    print(f"{BOLD}Workflow: {wid}{RESET}")
    print(f"  Title: {title}")

    if status_file.is_file():
        parent = _read_top_level_field(status_file, "parent_workflow")
        spawned = _read_list_field(status_file, "spawned_workflows")
        if parent:
            print(f"  Parent: {parent}")
        if spawned:
            print(f"  Spawned: {', '.join(spawned)}")

    # Stage progression bar
    stages = ["intent", "spec", "plan", "execution", "artifacts"]
    stage_statuses = []
    for st in stages:
        s = get_stage_status(status_file, st) if status_file.is_file() else "pending"
        if not s:
            s = "pending"
        stage_statuses.append(s)

    print()
    print("  Stages:")
    for st, ss in zip(stages, stage_statuses):
        icon = _STATUS_ICONS_STAGE.get(ss, "\u2b1c")
        print(f"    {icon} {st}: {ss}")

    # Phase details for active stage
    active_stage = ""
    for st, ss in zip(stages, stage_statuses):
        if ss in ("in_progress", "draft"):
            active_stage = st
            break
    if not active_stage:
        for st, ss in zip(stages, stage_statuses):
            if ss == "pending":
                active_stage = st
                break

    if active_stage and active_stage in STAGE_PHASES:
        phases = STAGE_PHASES[active_stage]
        print(f"\n  Phases ({active_stage}):")
        _PHASE_ICONS = {"pending": "\u2b1c", "in_progress": "\u23f3", "complete": "\u2705", "skipped": "\u23ed\ufe0f"}
        for p in phases:
            ps = _read_phase_status(status_file, active_stage, p) if status_file.is_file() else "pending"
            if not ps:
                ps = "pending"
            icon = _PHASE_ICONS.get(ps, "\u2753")
            print(f"    {icon} {p}: {ps}")

    # Execution graph summary
    gpath = _graph_path(wid)
    if gpath.is_file():
        g = ExecutionGraph.load(gpath)
        if g.nodes:
            summary = g.progress_summary()
            total = sum(summary.values())
            complete = summary.get("complete", 0)
            pct = int(100 * complete / total) if total > 0 else 0
            print(f"\n  Execution Graph: {complete}/{total} ({pct}%)")
            ready = g.ready_nodes()
            if ready:
                print(f"    Ready: {', '.join(n['id'] for n in ready)}")


