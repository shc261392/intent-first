def cmd_lock(args: list[str]) -> None:
    if len(args) < 2:
        print("Usage: intent-first lock <ID> <STAGE>")
        sys.exit(1)
    wid, stage_input = args[0], args[1]
    validate_workflow_id(wid)

    stage_file = resolve_stage(stage_input)
    if not stage_file:
        print(f"\u274c Unknown stage: {stage_input}")
        print("   Valid: intent, spec, plan, execution, artifacts (or 1-5)")
        sys.exit(1)

    target = WORKFLOW_DIR / wid / stage_file
    if not target.is_file():
        print(f"\u274c File not found: {target}")
        sys.exit(1)
    if target.is_symlink():
        print(f"\u274c Refusing to lock symlink: {target}")
        sys.exit(1)

    target.chmod(target.stat().st_mode & ~(stat.S_IWUSR | stat.S_IWGRP | stat.S_IWOTH))
    print(f"\U0001f512 Locked {target}")

    stage_key = resolve_stage_key(stage_input)
    status_file = WORKFLOW_DIR / wid / "status.yml"
    if status_file.is_file():
        ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        update_stage_field(status_file, stage_key, "status", "locked")
        update_stage_field(status_file, stage_key, "locked_at", ts)
        print(f"   Updated status.yml: {stage_key} \u2192 locked")


