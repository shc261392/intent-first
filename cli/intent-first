def cmd_new(args: list[str]) -> None:
    if not TEMPLATE_DIR.is_dir():
        print(f"\u274c Template directory not found: {TEMPLATE_DIR}")
        print(f"   Run: curl -fsSL https://raw.githubusercontent.com/{REPO}/main/install.sh | bash")
        sys.exit(1)

    wid = args[0] if args else next_number()
    if args:
        validate_workflow_id(wid)

    target = WORKFLOW_DIR / wid
    if target.exists():
        print(f"\u274c Workflow already exists: {target}")
        sys.exit(1)

    target.mkdir(parents=True)

    for tmpl in STAGE_FILES:
        src = TEMPLATE_DIR / tmpl
        if src.is_file():
            shutil.copy2(src, target / tmpl)
        else:
            warn(f"Template not found: {src} (skipped)")

    status_file = target / "status.yml"
    if status_file.is_file():
        text = re.sub(
            r"^workflow_id: .*",
            f'workflow_id: "{wid}"',
            status_file.read_text(),
            count=1,
            flags=re.MULTILINE,
        )
        status_file.write_text(text)

    print(f"\u2705 Created workflow \u2192 {target}/")
    print()
    print("Next steps:")
    print(f"  1. Edit {target}/s1_intent.md with your goals")
    print(f"  2. Tell your AI agent: /wf-spec {wid}")


