# ── Input validation ──────────────────────────────────────────

_ID_RE = re.compile(r"^[a-zA-Z0-9][a-zA-Z0-9_-]*$")


def validate_workflow_id(wid: str) -> None:
    if not _ID_RE.match(wid) or ".." in wid:
        print(f"\u274c Invalid workflow ID: {wid}")
        print("   Must start with alphanumeric, then alphanumeric/hyphens/underscores.")
        sys.exit(1)


def next_number() -> str:
    if not WORKFLOW_DIR.is_dir():
        return "1"
    max_n = 0
    for d in WORKFLOW_DIR.iterdir():
        if d.is_dir() and d.name.isdigit():
            max_n = max(max_n, int(d.name))
    return str(max_n + 1)


# ── Stage helpers ─────────────────────────────────────────────

_STAGE_FILE: dict[str, str] = {
    "1": "s1_intent.md",    "intent":    "s1_intent.md",
    "2": "s2_spec.md",      "spec":      "s2_spec.md",
    "3": "s3_plan.md",      "plan":      "s3_plan.md",
    "4": "s4_execution.md", "execution": "s4_execution.md",
    "5": "s5_artifacts.md", "artifacts": "s5_artifacts.md",
}

_STAGE_KEY: dict[str, str] = {
    "1": "intent",    "intent":    "intent",
    "2": "spec",      "spec":      "spec",
    "3": "plan",      "plan":      "plan",
    "4": "execution", "execution": "execution",
    "5": "artifacts", "artifacts": "artifacts",
}


def resolve_stage(s: str) -> str:
    return _STAGE_FILE.get(s, "")


def resolve_stage_key(s: str) -> str:
    return _STAGE_KEY.get(s, "")


def get_stage_status(status_file: Path, stage: str) -> str:
    """Read a stage's status field from status.yml without a YAML parser."""
    if not status_file.is_file():
        return ""
    in_stage = False
    for line in status_file.read_text().splitlines():
        if re.match(r"^  [a-z]", line):
            in_stage = line.strip().startswith(f"{stage}:")
        if in_stage and re.match(r"^    status:", line):
            return line.split(":", 1)[1].strip().strip('"').split("#")[0].strip()
    return ""


def update_stage_field(status_file: Path, stage: str, field: str, value: str) -> None:
    """Update one field in a status.yml stage block. Preserves all comments."""
    if not status_file.is_file() or not os.access(status_file, os.W_OK):
        return
    lines = status_file.read_text().splitlines(keepends=True)
    in_stage = False
    for i, line in enumerate(lines):
        if re.match(r"^  [a-z]", line):
            in_stage = line.strip().startswith(f"{stage}:")
        if in_stage and re.match(rf"^    {re.escape(field)}:", line):
            lines[i] = f'    {field}: "{value}"\n'
            break
    fd, tmp = tempfile.mkstemp(dir=status_file.parent)
    try:
        with os.fdopen(fd, "w") as f:
            f.writelines(lines)
        Path(tmp).replace(status_file)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass


# ── Prompt / agent installer ─────────────────────────────────

def _install_prompts_and_agents(tools: list[str]) -> None:
    """Download latest prompts and agent files into all detected tool directories."""
    installed_prompt_dirs: list[Path] = []
    installed_agent_dirs:  list[Path] = []

    for t in tools:
        dirs = _TOOL_DIRS.get(t)
        if not dirs:
            continue
        prompt_dir_str, agent_dir_str = dirs
        if prompt_dir_str:
            pd = Path(prompt_dir_str)
            pd.mkdir(parents=True, exist_ok=True)
            for fname in INTENT_FIRST_PROMPTS:
                tmp_path = None
                try:
                    fd, tmp = tempfile.mkstemp(dir=pd)
                    os.close(fd)
                    tmp_path = Path(tmp)
                    if _download(f"{RAW}/prompts/{fname}", tmp_path):
                        tmp_path.replace(pd / fname)
                        tmp_path = None
                except Exception as exc:
                    warn(f"Failed to install prompt {fname}: {exc}")
                finally:
                    if tmp_path and tmp_path.exists():
                        tmp_path.unlink()
            if pd not in installed_prompt_dirs:
                installed_prompt_dirs.append(pd)
        if agent_dir_str:
            ad = Path(agent_dir_str)
            ad.mkdir(parents=True, exist_ok=True)
            for fname in INTENT_FIRST_AGENTS:
                tmp_path = None
                try:
                    fd, tmp = tempfile.mkstemp(dir=ad)
                    os.close(fd)
                    tmp_path = Path(tmp)
                    if _download(f"{RAW}/agents/{fname}", tmp_path):
                        tmp_path.replace(ad / fname)
                        tmp_path = None
                except Exception as exc:
                    warn(f"Failed to install agent {fname}: {exc}")
                finally:
                    if tmp_path and tmp_path.exists():
                        tmp_path.unlink()
            if ad not in installed_agent_dirs:
                installed_agent_dirs.append(ad)

    for pd in installed_prompt_dirs:
        info(f"Installed {len(INTENT_FIRST_PROMPTS)} prompts → {pd}/")
    for ad in installed_agent_dirs:
        info(f"Installed {len(INTENT_FIRST_AGENTS)} agents → {ad}/")


# ── cmd_new ───────────────────────────────────────────────────

def cmd_new(args: list[str]) -> None:
    if not TEMPLATE_DIR.is_dir():
        print(f"\u274c Template directory not found: {TEMPLATE_DIR}")
        print(f"   Run: curl -fsSL https://raw.githubusercontent.com/{REPO}/main/install.sh | bash")
        sys.exit(1)

    wid = args[0] if args else next_number()
    if args:
        validate_workflow_id(wid)

    target = WORKFLOW_DIR / wid
    if target.exists():
        print(f"\u274c Workflow already exists: {target}")
        sys.exit(1)

    target.mkdir(parents=True)

    for tmpl in STAGE_FILES:
        src = TEMPLATE_DIR / tmpl
        if src.is_file():
            shutil.copy2(src, target / tmpl)
        else:
            warn(f"Template not found: {src} (skipped)")

    status_file = target / "status.yml"
    if status_file.is_file():
        text = re.sub(
            r"^workflow_id: .*",
            f'workflow_id: "{wid}"',
            status_file.read_text(),
            count=1,
            flags=re.MULTILINE,
        )
        status_file.write_text(text)

    print(f"\u2705 Created workflow \u2192 {target}/")
    print()
    print("Next steps:")
    print(f"  1. Edit {target}/s1_intent.md with your goals")
    print(f"  2. Tell your AI agent: /wf-spec {wid}")


# ── cmd_lock / cmd_unlock ─────────────────────────────────────

def cmd_lock(args: list[str]) -> None:
    if len(args) < 2:
        print("Usage: intent-first lock <ID> <STAGE>")
        sys.exit(1)
    wid, stage_input = args[0], args[1]
    validate_workflow_id(wid)

    stage_file = resolve_stage(stage_input)
    if not stage_file:
        print(f"\u274c Unknown stage: {stage_input}")
        print("   Valid: intent, spec, plan, execution, artifacts (or 1-5)")
        sys.exit(1)

    target = WORKFLOW_DIR / wid / stage_file
    if not target.is_file():
        print(f"\u274c File not found: {target}")
        sys.exit(1)
    if target.is_symlink():
        print(f"\u274c Refusing to lock symlink: {target}")
        sys.exit(1)

    target.chmod(target.stat().st_mode & ~(stat.S_IWUSR | stat.S_IWGRP | stat.S_IWOTH))
    print(f"\U0001f512 Locked {target}")

    stage_key = resolve_stage_key(stage_input)
    status_file = WORKFLOW_DIR / wid / "status.yml"
    if status_file.is_file():
        ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        update_stage_field(status_file, stage_key, "status", "locked")
        update_stage_field(status_file, stage_key, "locked_at", ts)
        print(f"   Updated status.yml: {stage_key} \u2192 locked")


def cmd_unlock(args: list[str]) -> None:
    if len(args) < 2:
        print("Usage: intent-first unlock <ID> <STAGE>")
        sys.exit(1)
    wid, stage_input = args[0], args[1]
    validate_workflow_id(wid)

    stage_file = resolve_stage(stage_input)
    if not stage_file:
        print(f"\u274c Unknown stage: {stage_input}")
        print("   Valid: intent, spec, plan, execution, artifacts (or 1-5)")
        sys.exit(1)

    target = WORKFLOW_DIR / wid / stage_file
    if not target.is_file():
        print(f"\u274c File not found: {target}")
        sys.exit(1)

    target.chmod(target.stat().st_mode | stat.S_IWUSR)
    print(f"\U0001f513 Unlocked {target}")


# ── cmd_validate ──────────────────────────────────────────────

def _validate_one(directory: Path) -> int:
    wid = directory.name
    issues = 0
    for f in STAGE_FILES:
        if not (directory / f).is_file():
            print(f"  \u274c Missing: {directory / f}")
            issues += 1

    status_file = directory / "status.yml"
    if status_file.is_file():
        for stage, fname in [
            ("spec",      "s2_spec.md"),
            ("plan",      "s3_plan.md"),
            ("execution", "s4_execution.md"),
            ("artifacts", "s5_artifacts.md"),
        ]:
            st = get_stage_status(status_file, stage)
            fpath = directory / fname
            if not st:
                print(f"  \u26a0\ufe0f  {status_file}: Missing status for stage '{stage}'")
                issues += 1
            elif st == "locked" and fpath.is_file() and os.access(fpath, os.W_OK):
                print(f"  \u26a0\ufe0f  {fpath}: status.yml says 'locked' but file is writable")
                print(f"       Fix: intent-first lock {wid} {stage}")
                issues += 1

    if issues == 0:
        print(f"  \u2705 {wid}: OK")
    return issues


def cmd_validate(args: list[str]) -> None:
    target_id = args[0] if args else ""
    if target_id:
        validate_workflow_id(target_id)

    errors, checked = 0, 0

    if target_id:
        d = WORKFLOW_DIR / target_id
        if not d.is_dir():
            print(f"\u274c Workflow not found: {d}")
            sys.exit(1)
        print(f"Validating {target_id}...")
        errors = _validate_one(d)
        checked = 1
    else:
        if not WORKFLOW_DIR.is_dir():
            print("No workflow directory found. Run: intent-first init")
            return
        for d in _sorted_workflows():
            print(f"Validating {d.name}...")
            errors += _validate_one(d)
            checked += 1

    print()
    if checked == 0:
        print("No workflows found.")
    elif errors == 0:
        print(f"\u2705 All {checked} workflow(s) valid.")
    else:
        print(f"\u26a0\ufe0f  {errors} issue(s) across {checked} workflow(s).")
        sys.exit(1)


# ── cmd_list ──────────────────────────────────────────────────

def _sorted_workflows() -> list[Path]:
    """Numeric IDs first (ascending), then slugs alphabetically."""
    if not WORKFLOW_DIR.is_dir():
        return []
    dirs = [d for d in WORKFLOW_DIR.iterdir() if d.is_dir()]
    return sorted(dirs, key=lambda p: (0, int(p.name)) if p.name.isdigit() else (1, p.name))


def cmd_list(_args: list[str]) -> None:
    if not WORKFLOW_DIR.is_dir():
        print("No workflows yet. Run: intent-first new")
        return

    print(f"{'ID':<15} {'TITLE':<30} STATUS")
    print(f"{'---':<15} {'---':<30} ---")

    for d in _sorted_workflows():
        wid = d.name
        title = "(untitled)"
        intent_file = d / "s1_intent.md"
        if intent_file.is_file():
            for line in intent_file.read_text().splitlines():
                m = re.match(r"^# Intent:\s*(.*)", line)
                if m:
                    title = m.group(1).strip()
                    break

        display_status = "\U0001f4a1 intent"
        status_file = d / "status.yml"
        if status_file.is_file():
            a = get_stage_status(status_file, "artifacts")
            e = get_stage_status(status_file, "execution")
            p = get_stage_status(status_file, "plan")
            s = get_stage_status(status_file, "spec")
            if   a in ("complete", "locked"):  display_status = "\u2705 complete"
            elif e == "in_progress":           display_status = "\u2699\ufe0f  executing"
            elif p in ("locked", "approved"):  display_status = "\U0001f4cb planned"
            elif s in ("locked", "approved"):  display_status = "\U0001f4d0 specified"

        print(f"{wid:<15} {title[:30]:<30} {display_status}")


# ── cmd_init ──────────────────────────────────────────────────

def _init_rules_oneliner(dest: Path, line: str) -> None:
    dest.parent.mkdir(parents=True, exist_ok=True)
    if dest.is_file():
        if "intent-first" not in dest.read_text().lower():
            with dest.open("a") as f:
                f.write(f"\n{line}\n")
            info(f"Added Intent-First reference \u2192 {dest}")
        else:
            info(f"{dest} already references Intent-First (skipped)")
    else:
        dest.write_text(f"{line}\n")
        info(f"Created {dest} with Intent-First reference")


_TOOL_FILES: dict[str, Path] = {
    "copilot":  Path(".github/copilot-instructions.md"),
    "cursor":   Path(".cursor/rules/intent-first.md"),
    "claude":   Path("CLAUDE.md"),
    "windsurf": Path(".windsurfrules"),
    "aider":    Path(".aider.rules.md"),
    "cline":    Path(".clinerules"),
}


def cmd_init(args: list[str]) -> None:
    tool = "auto"
    i = 0
    while i < len(args):
        if args[i] == "--tool" and i + 1 < len(args):
            tool = args[i + 1]; i += 2
        else:
            tool = args[i]; i += 1

    print()
    print(f"{BOLD}Initializing Intent-First in this project...{RESET}")
    print()

    Path(".intent-first").mkdir(exist_ok=True)

    global_rules = INTENT_FIRST_HOME / "rules.md"
    if global_rules.is_file():
        shutil.copy2(global_rules, ".intent-first/rules.md")
        info("Created .intent-first/rules.md")
    else:
        warn(f"Global rules not found at {global_rules}")
        print("  Re-run the installer, then try again:")
        print(f"    curl -fsSL https://raw.githubusercontent.com/{REPO}/main/install.sh | bash")
        sys.exit(1)

    gitignore = Path(".gitignore")
    marker = ".intent-first/workflows/"
    if gitignore.is_file():
        if marker not in gitignore.read_text():
            with gitignore.open("a") as f:
                f.write(f"\n# Intent-First workflow data (ephemeral \u2014 do not commit)\n{marker}\n")
            info("Added .intent-first/workflows/ to .gitignore")
        else:
            info(".gitignore already covers .intent-first/workflows/ (skipped)")
    else:
        gitignore.write_text(f"# Intent-First workflow data (ephemeral \u2014 do not commit)\n{marker}\n")
        info("Created .gitignore with .intent-first/workflows/")

    if tool == "auto":
        tools = []
        if Path(".github").is_dir() or Path(".github/copilot-instructions.md").is_file():
            tools.append("copilot")
        if Path(".cursor").is_dir() or Path(".cursorrules").is_file():
            tools.append("cursor")
        if Path("CLAUDE.md").is_file():
            tools.append("claude")
        if Path(".windsurfrules").is_file():
            tools.append("windsurf")
        if Path(".aider.conf.yml").is_file() or Path(".aiderignore").is_file():
            tools.append("aider")
        if Path(".clinerules").is_file() or Path(".cline").is_dir():
            tools.append("cline")
        if not tools:
            tools = ["copilot", "cursor", "claude"]
    else:
        tools = [tool]

    one_liner = "For the Intent-First Agentic Workflow, see `.intent-first/rules.md`."
    for t in tools:
        if t in _TOOL_FILES:
            _init_rules_oneliner(_TOOL_FILES[t], one_liner)

    step("Installing prompts and agents...")
    _install_prompts_and_agents(tools)

    print()
    print(f"{GREEN}\u2705 Intent-First initialized!{RESET}")
    print()
    print("  Commit .intent-first/rules.md \u2014 it's your project-local workflow ruleset.")
    print("  .intent-first/workflows/ is gitignored \u2014 workflow data stays local.")
    print()
    print("  Start your first workflow:")
    print("    intent-first new")


# ── cmd_upgrade ───────────────────────────────────────────────

def cmd_upgrade(_args: list[str]) -> None:
    print()
    print(f"{BOLD}Upgrading Intent-First...{RESET}")
    print()

    text = _fetch_text(f"https://api.github.com/repos/{REPO}/releases/latest")
    latest = ""
    if text:
        try:
            latest = json.loads(text).get("tag_name", "")
        except (json.JSONDecodeError, AttributeError):
            pass
    if not latest:
        print("\u274c Could not fetch latest version. Check your internet connection.")
        sys.exit(1)

    current = f"v{VERSION}"
    if latest in (current, VERSION):
        print(f"\u2705 CLI already up to date ({current}) — refreshing prompts, agents, and templates...")
    else:
        print(f"  Current: {current}")
        print(f"  Latest:  {latest}")
        print()

    cli_dest       = INTENT_FIRST_HOME / "bin" / "intent-first"
    templates_dest = INTENT_FIRST_HOME / "templates"
    rules_dest     = INTENT_FIRST_HOME / "rules.md"

    if templates_dest.is_dir():
        bk = templates_dest.parent / "templates.bk"
        if bk.exists():
            shutil.rmtree(bk)
        shutil.copytree(templates_dest, bk)
        info("Backed up templates \u2192 templates.bk")

    if latest not in (current, VERSION):
        step("Downloading CLI...")
        bin_dir = INTENT_FIRST_HOME / "bin"
        bin_dir.mkdir(parents=True, exist_ok=True)
        fd, tmp = tempfile.mkstemp(dir=bin_dir)
        os.close(fd)
        tmp_path = Path(tmp)
        if not _download(f"{RAW}/cli/intent-first", tmp_path):
            print("\u274c Failed to download new CLI")
            tmp_path.unlink()
            sys.exit(1)
        tmp_path.chmod(tmp_path.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
        tmp_path.replace(cli_dest)
        info(f"CLI upgraded \u2192 {cli_dest}")

    step("Downloading templates...")
    templates_dest.mkdir(parents=True, exist_ok=True)
    for tmpl in STAGE_FILES:
        fd, tmp = tempfile.mkstemp(dir=templates_dest)
        os.close(fd)
        tmp_path = Path(tmp)
        if _download(f"{RAW}/templates/{tmpl}", tmp_path):
            tmp_path.replace(templates_dest / tmpl)
            info(f"Template: {tmpl}")
        else:
            tmp_path.unlink()

    step("Downloading rules...")
    fd, tmp = tempfile.mkstemp(dir=INTENT_FIRST_HOME)
    os.close(fd)
    tmp_path = Path(tmp)
    if _download(f"{RAW}/rules/RULES.md", tmp_path):
        tmp_path.replace(rules_dest)
        info(f"Rules updated \u2192 {rules_dest}")
    else:
        tmp_path.unlink()

    step("Refreshing prompts and agents in detected tool directories...")
    # Detect which tools are present in the current directory (if any)
    upgrade_tools: list[str] = []
    for t, dirs in _TOOL_DIRS.items():
        prompt_dir, agent_dir = dirs
        if prompt_dir and Path(prompt_dir).is_dir():
            upgrade_tools.append(t)
        elif agent_dir and Path(agent_dir).is_dir():
            upgrade_tools.append(t)
    # Fallback: refresh all dirs that already exist globally
    if not upgrade_tools:
        for t, dirs in _TOOL_DIRS.items():
            prompt_dir, agent_dir = dirs
            if (prompt_dir and Path(prompt_dir).is_dir()) or \
               (agent_dir and Path(agent_dir).is_dir()):
                upgrade_tools.append(t)
    if upgrade_tools:
        _install_prompts_and_agents(list(dict.fromkeys(upgrade_tools)))
    else:
        warn("No tool directories found in current directory — skipping prompt/agent refresh.")
        warn("Run 'intent-first init' inside your project to install them.")

    if latest not in (current, VERSION):
        VERSION_CACHE.write_text(f"{latest}:{int(time.time())}")
        print()
        print(f"{GREEN}\u2705 Upgraded to {latest}{RESET}")
    else:
        print()
        print(f"{GREEN}\u2705 Everything refreshed ({current}){RESET}")
    print()
    print("  Per-project .intent-first/rules.md files are NOT auto-updated.")
    print("  Run 'intent-first init' in each project to refresh local rules.")


# ── cmd_implode ───────────────────────────────────────────────

def _is_rules_only_intent_first(path: Path) -> bool:
    """True if file contains only an Intent-First reference (safe to delete)."""
    if path.is_symlink():
        return False
    try:
        text = path.read_text()
    except OSError:
        return False
    non_empty = [
        line for line in text.splitlines()
        if line.strip() and not line.strip().startswith(("#", "<!--", "-->", ">"))
    ]
    if not non_empty:
        return True
    if_lines = [line for line in non_empty if "intent-first" in line.lower()]
    return len(if_lines) >= len(non_empty)


def cmd_implode(_args: list[str]) -> None:
    print()
    print(f"{BOLD}\u26a0\ufe0f  Intent-First Implode{RESET}")
    print()
    print("Removes all intent-first installed files. Workflow data is kept.")
    print()
    try:
        confirm = input("Type 'implode' to confirm: ").strip()
    except (EOFError, KeyboardInterrupt):
        print("\nAborted.")
        return
    if confirm != "implode":
        print("Aborted.")
        return
    print()

    unsafe_files: list[Path] = []
    removed = 0

    for prompt_dir_str in TOOL_PROMPT_DIRS:
        prompt_dir = Path(prompt_dir_str)
        if not prompt_dir.is_dir():
            continue
        for prompt in INTENT_FIRST_PROMPTS:
            target = prompt_dir / prompt
            if target.is_symlink():
                print(f"  \u26a0\ufe0f  SKIPPED {target} (symlink)")
            elif target.is_file():
                target.unlink()
                print(f"  \u2713 Removed {target}")
                removed += 1
        try:
            prompt_dir.rmdir()
            print(f"  \u2713 Removed empty {prompt_dir}/")
        except OSError:
            pass

    for rules_str in TOOL_RULES:
        rules_file = Path(rules_str)
        if not rules_file.is_file():
            continue
        if _is_rules_only_intent_first(rules_file):
            rules_file.unlink()
            print(f"  \u2713 Removed {rules_file}")
            removed += 1
            parent = rules_file.parent
            if parent != Path("."):
                try:
                    parent.rmdir()
                except OSError:
                    pass
        else:
            unsafe_files.append(rules_file)
            print(f"  \u26a0\ufe0f  SKIPPED {rules_file} (has other content)")

    local_rules = Path(".intent-first/rules.md")
    if local_rules.is_file():
        local_rules.unlink()
        print(f"  \u2713 Removed {local_rules}")
        removed += 1

    global_cli = INTENT_FIRST_HOME / "bin" / "intent-first"
    if global_cli.is_file():
        global_cli.unlink()
        print(f"  \u2713 Removed {global_cli}")
        removed += 1
        try:
            (INTENT_FIRST_HOME / "bin").rmdir()
        except OSError:
            pass

    try:
        Path(".intent-first").rmdir()
        print("  \u2713 Removed .intent-first/")
    except OSError:
        pass

    print()
    print(f"\u2705 Removed {removed} item(s).")

    if unsafe_files:
        print()
        print(f"{YELLOW}Files with mixed content (not deleted):{RESET}")
        for f in unsafe_files:
            print(f"   {f} \u2014 manually remove the Intent-First reference line")


# ── Main ──────────────────────────────────────────────────────

def main() -> None:
    args = sys.argv[1:]
    cmd  = args[0] if args else "help"

    if cmd not in ("upgrade", "help", "--help", "-h", "implode"):
        check_latest_version()

    dispatch = {
        "init":     lambda: cmd_init(args[1:]),
        "new":      lambda: cmd_new(args[1:]),
        "lock":     lambda: cmd_lock(args[1:]),
        "unlock":   lambda: cmd_unlock(args[1:]),
        "validate": lambda: cmd_validate(args[1:]),
        "list":     lambda: cmd_list(args[1:]),
        "upgrade":  lambda: cmd_upgrade(args[1:]),
        "implode":  lambda: cmd_implode(args[1:]),
        "help":     usage,
        "--help":   usage,
        "-h":       usage,
    }

    fn = dispatch.get(cmd)
    if fn is None:
        print(f"Unknown command: {cmd}")
        usage()
        sys.exit(1)
    fn()


if __name__ == "__main__":
    main()
