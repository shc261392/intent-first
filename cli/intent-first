def main() -> None:
    args = sys.argv[1:]
    cmd  = args[0] if args else "help"

    if cmd not in ("upgrade", "help", "--help", "-h", "implode", "configure"):
        check_latest_version()

    dispatch = {
        "init":           lambda: cmd_init(args[1:]),
        "new":            lambda: cmd_new(args[1:]),
        "lock":           lambda: cmd_lock(args[1:]),
        "unlock":         lambda: cmd_unlock(args[1:]),
        "status-update":  lambda: cmd_status_update(args[1:]),
        "phase-update":   lambda: cmd_phase_update(args[1:]),
        "phase-list":     lambda: cmd_phase_list(args[1:]),
        "graph":          lambda: cmd_graph(args[1:]),
        "configure":      lambda: cmd_configure(args[1:]),
        "spawn":          lambda: cmd_spawn(args[1:]),
        "link":           lambda: cmd_link(args[1:]),
        "status":         lambda: cmd_status(args[1:]),
        "validate":       lambda: cmd_validate(args[1:]),
        "list":           lambda: cmd_list(args[1:]),
        "upgrade":        lambda: cmd_upgrade(args[1:]),
        "implode":        lambda: cmd_implode(args[1:]),
        "help":           usage,
        "--help":         usage,
        "-h":             usage,
    }

    fn = dispatch.get(cmd)
    if fn is None:
        print(f"Unknown command: {cmd}")
        usage()
        sys.exit(1)
    fn()


if __name__ == "__main__":
    main()
