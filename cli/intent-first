# ── cmd_graph ─────────────────────────────────────────────────

def cmd_graph(args: list[str]) -> None:
    """Execution graph management commands."""
    if len(args) < 2:
        print("Usage: intent-first graph <create|show|ready|update|validate> <ID> [...]")
        sys.exit(1)

    subcmd = args[0]
    wid = args[1]
    validate_workflow_id(wid)

    gpath = _graph_path(wid)

    if subcmd == "create":
        if gpath.exists():
            print(f"\u274c Graph already exists: {gpath}")
            sys.exit(1)
        g = ExecutionGraph()
        # Create with empty nodes — agents populate it
        gpath.parent.mkdir(parents=True, exist_ok=True)
        g.save(gpath)
        print(f"\u2705 Created execution graph \u2192 {gpath}")

    elif subcmd == "show":
        if not gpath.is_file():
            print(f"\u274c No execution graph found: {gpath}")
            print(f"   Create one with: intent-first graph create {wid}")
            sys.exit(1)
        g = ExecutionGraph.load(gpath)
        if not g.nodes:
            print("(empty graph — no nodes defined)")
            return
        summary = g.progress_summary()
        total = sum(summary.values())
        complete = summary.get("complete", 0)
        print(f"Execution Graph: {wid} ({complete}/{total} complete)")
        print()
        dm = g.depth_map()
        _STATUS_ICONS_G = {"pending": "\u2b1c", "in_progress": "\u23f3", "complete": "\u2705", "failed": "\u274c", "blocked": "\U0001f6ab"}
        # Group by depth level
        levels: dict[int, list[dict]] = {}
        for n in g.nodes:
            d = dm.get(n["id"], 0)
            levels.setdefault(d, []).append(n)
        for depth in sorted(levels.keys()):
            for n in levels[depth]:
                icon = _STATUS_ICONS_G.get(n.get("status", "pending"), "\u2753")
                deps = ", ".join(n.get("depends_on", [])) or "(none)"
                pad = "  " * depth
                print(f"  {pad}{icon} {n['id']}: {n.get('name', '')}  [deps: {deps}]")
        print()
        print(f"  Parallelism: effective={g.parallelism.get('effective', 1)}")

    elif subcmd == "ready":
        if not gpath.is_file():
            print(f"\u274c No execution graph found: {gpath}")
            sys.exit(1)
        g = ExecutionGraph.load(gpath)
        ready = g.ready_nodes()
        if not ready:
            print("No nodes ready for execution.")
            summary = g.progress_summary()
            if summary.get("failed", 0) > 0:
                print("  (some nodes are failed — resolve them first)")
            elif summary.get("in_progress", 0) > 0:
                print("  (some nodes are in progress)")
            elif all(n.get("status") == "complete" for n in g.nodes):
                print("  (all nodes complete!)")
            return
        print("Ready nodes:")
        for n in ready:
            print(f"  \u2192 {n['id']}: {n.get('name', '')}")

    elif subcmd == "update":
        if not gpath.is_file():
            print(f"\u274c No execution graph found: {gpath}")
            sys.exit(1)
        if len(args) < 3:
            print("Usage: intent-first graph update <ID> <NODE_ID> --status <STATUS>")
            sys.exit(1)
        node_id = args[2]
        # Parse flags
        updates: dict[str, str] = {}
        i = 3
        while i < len(args):
            if args[i].startswith("--"):
                field = args[i][2:].replace("-", "_")
                if i + 1 >= len(args):
                    print(f"\u274c Missing value for --{field}")
                    sys.exit(1)
                updates[field] = args[i + 1]
                i += 2
            else:
                i += 1

        g = ExecutionGraph.load(gpath)
        nm = g._node_map()
        if node_id not in nm:
            print(f"\u274c Unknown node: {node_id}")
            print(f"   Known nodes: {', '.join(nm.keys())}")
            sys.exit(1)

        status_val = updates.get("status", "")
        if status_val == "in_progress":
            g.start_node(node_id)
        elif status_val == "complete":
            g.complete_node(node_id)
        elif status_val == "failed":
            g.fail_node(node_id)
        elif status_val == "pending":
            g.reset_node(node_id)
        else:
            print(f"\u274c Invalid status: {status_val}")
            print("   Valid: pending, in_progress, complete, failed")
            sys.exit(1)
        g.save(gpath)
        print(f"\u2705 {node_id}: {status_val}")

    elif subcmd == "validate":
        if not gpath.is_file():
            print(f"\u274c No execution graph found: {gpath}")
            sys.exit(1)
        g = ExecutionGraph.load(gpath)
        issues = g.validate()
        if issues:
            print("Graph validation issues:")
            for issue in issues:
                print(f"  \u274c {issue}")
            sys.exit(1)
        else:
            total = len(g.nodes)
            print(f"\u2705 Graph valid ({total} node{'s' if total != 1 else ''})")

    else:
        print(f"\u274c Unknown graph subcommand: {subcmd}")
        print("   Valid: create, show, ready, update, validate")
        sys.exit(1)


