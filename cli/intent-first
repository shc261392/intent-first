def get_stage_status(status_file: Path, stage: str) -> str:
    """Read a stage's status field from status.yml without a YAML parser."""
    if not status_file.is_file():
        return ""
    in_stage = False
    for line in status_file.read_text().splitlines():
        if re.match(r"^  [a-z]", line):
            in_stage = line.strip().startswith(f"{stage}:")
        if in_stage and re.match(r"^    status:", line):
            return line.split(":", 1)[1].strip().strip('"').split("#")[0].strip()
    return ""


def update_stage_field(status_file: Path, stage: str, field: str, value: str) -> None:
    """Update one field in a status.yml stage block. Preserves all comments."""
    if not status_file.is_file() or not os.access(status_file, os.W_OK):
        return
    lines = status_file.read_text().splitlines(keepends=True)
    in_stage = False
    for i, line in enumerate(lines):
        if re.match(r"^  [a-z]", line):
            in_stage = line.strip().startswith(f"{stage}:")
        if in_stage and re.match(rf"^    {re.escape(field)}:", line):
            lines[i] = f'    {field}: "{value}"\n'
            break
    fd, tmp = tempfile.mkstemp(dir=status_file.parent)
    try:
        with os.fdopen(fd, "w") as f:
            f.writelines(lines)
        Path(tmp).replace(status_file)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass


# ── Config helpers ────────────────────────────────────────────

def _read_config() -> dict[str, str]:
    """Read ~/.intent-first/config.yml as simple key: value pairs."""
    cfg: dict[str, str] = {}
    if CONFIG_FILE.is_file():
        for line in CONFIG_FILE.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and ":" in line:
                k, v = line.split(":", 1)
                cfg[k.strip()] = v.strip().strip('"').strip("'")
    return cfg


def _write_config(cfg: dict[str, str]) -> None:
    """Write config as simple YAML-like key: value pairs."""
    INTENT_FIRST_HOME.mkdir(parents=True, exist_ok=True)
    lines = ["# Intent-First user configuration\n"]
    for k, v in cfg.items():
        lines.append(f'{k}: "{v}"\n')
    CONFIG_FILE.write_text("".join(lines))


def get_config_value(key: str) -> str:
    """Get a single config value by key."""
    return _read_config().get(key, "")


# ── Phase helpers ─────────────────────────────────────────────

def _read_phase_status(status_file: Path, stage: str, phase: str) -> str:
    """Read a phase status from status.yml. Returns empty string if not found."""
    if not status_file.is_file():
        return ""
    text = status_file.read_text()
    # Find the stage block, then the phases block, then the specific phase
    in_stage = False
    in_phases = False
    in_phase = False
    for line in text.splitlines():
        if re.match(r"^  [a-z]", line) and not re.match(r"^    ", line):
            in_stage = line.strip().startswith(f"{stage}:")
            in_phases = False
            in_phase = False
        if in_stage and line.strip() == "phases:":
            in_phases = True
            continue
        if in_phases and re.match(r"^      [a-z]", line):
            in_phase = line.strip().startswith(f"{phase}:")
        if in_phase and re.match(r"^        status:", line):
            return line.split(":", 1)[1].strip().strip('"').split("#")[0].strip()
        # Exit phases block if we hit a non-indented line
        if in_phases and re.match(r"^    [a-z]", line) and not re.match(r"^      ", line):
            if not line.strip().startswith("phases:"):
                in_phases = False
    return ""


def _update_phase_field(status_file: Path, stage: str, phase: str, field: str, value: str) -> None:
    """Update a field in a phase block within status.yml."""
    if not status_file.is_file() or not os.access(status_file, os.W_OK):
        return
    lines = status_file.read_text().splitlines(keepends=True)
    in_stage = False
    in_phases = False
    in_phase = False
    for i, line in enumerate(lines):
        stripped = line.rstrip("\n")
        if re.match(r"^  [a-z]", stripped) and not re.match(r"^    ", stripped):
            in_stage = stripped.strip().startswith(f"{stage}:")
            in_phases = False
            in_phase = False
        if in_stage and stripped.strip() == "phases:":
            in_phases = True
            continue
        if in_phases and re.match(r"^      [a-z]", stripped):
            in_phase = stripped.strip().startswith(f"{phase}:")
        if in_phase and re.match(rf"^        {re.escape(field)}:", stripped):
            lines[i] = f'        {field}: "{value}"\n'
            break
        if in_phases and re.match(r"^    [a-z]", stripped) and not re.match(r"^      ", stripped):
            if not stripped.strip().startswith("phases:"):
                in_phases = False
    fd, tmp = tempfile.mkstemp(dir=status_file.parent)
    try:
        with os.fdopen(fd, "w") as f:
            f.writelines(lines)
        Path(tmp).replace(status_file)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass


# ── Execution Graph Engine ────────────────────────────────────

class ExecutionGraph:
    """Zero-dependency DAG engine for execution graph management.
    
    Stores/loads graph as JSON (Python stdlib) since the nested structure
    is too complex for the line-by-line YAML parser. The file is named
    execution-graph.json in the workflow directory.
    """

    def __init__(self) -> None:
        self.nodes: list[dict] = []
        self.parallelism: dict[str, object] = {
            "max_graph": 3,
            "max_agent": 1,
            "max_configured": None,
            "effective": 1,
        }

    @classmethod
    def load(cls, path: Path) -> "ExecutionGraph":
        g = cls()
        if path.is_file():
            data = json.loads(path.read_text())
            graph = data.get("graph", data)
            g.nodes = graph.get("nodes", [])
            g.parallelism = graph.get("parallelism", g.parallelism)
        return g

    def save(self, path: Path) -> None:
        data = {"graph": {"nodes": self.nodes, "parallelism": self.parallelism}}
        path.write_text(json.dumps(data, indent=2) + "\n")

    def _node_map(self) -> dict[str, dict]:
        return {n["id"]: n for n in self.nodes}

    def ready_nodes(self) -> list[dict]:
        """Return nodes whose deps are all complete and own status is pending."""
        nm = self._node_map()
        ready = []
        for n in self.nodes:
            if n.get("status") != "pending":
                continue
            deps = n.get("depends_on", [])
            if all(nm.get(d, {}).get("status") == "complete" for d in deps):
                ready.append(n)
        return ready

    def start_node(self, node_id: str) -> bool:
        for n in self.nodes:
            if n["id"] == node_id:
                n["status"] = "in_progress"
                n["started_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                return True
        return False

    def complete_node(self, node_id: str) -> bool:
        for n in self.nodes:
            if n["id"] == node_id:
                n["status"] = "complete"
                n["completed_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
                return True
        return False

    def fail_node(self, node_id: str) -> bool:
        for n in self.nodes:
            if n["id"] == node_id:
                n["status"] = "failed"
                # Propagate blocked to descendants
                self._propagate_blocked(node_id)
                return True
        return False

    def _propagate_blocked(self, failed_id: str) -> None:
        """Mark all transitive dependents of a failed node as blocked."""
        nm = self._node_map()
        queue = [failed_id]
        visited: set[str] = set()
        while queue:
            current = queue.pop(0)
            for n in self.nodes:
                if current in n.get("depends_on", []) and n["id"] not in visited:
                    if n.get("status") in ("pending", "in_progress"):
                        n["status"] = "blocked"
                    visited.add(n["id"])
                    queue.append(n["id"])

    def reset_node(self, node_id: str) -> bool:
        for n in self.nodes:
            if n["id"] == node_id:
                n["status"] = "pending"
                n["started_at"] = ""
                n["completed_at"] = ""
                return True
        return False

    def validate(self) -> list[str]:
        """Check for cycles, missing deps, orphans. Returns list of issues."""
        issues: list[str] = []
        nm = self._node_map()
        ids = set(nm.keys())
        # Check missing deps
        for n in self.nodes:
            for d in n.get("depends_on", []):
                if d not in ids:
                    issues.append(f"Node '{n['id']}' depends on unknown node '{d}'")
        # Cycle detection via DFS
        WHITE, GRAY, BLACK = 0, 1, 2
        color: dict[str, int] = {nid: WHITE for nid in ids}

        def dfs(nid: str) -> bool:
            color[nid] = GRAY
            node = nm[nid]
            for dep_id in node.get("depends_on", []):
                if dep_id not in color:
                    continue
                if color[dep_id] == GRAY:
                    issues.append(f"Cycle detected involving node '{dep_id}'")
                    return True
                if color[dep_id] == WHITE:
                    if dfs(dep_id):
                        return True
            color[nid] = BLACK
            return False

        for nid in ids:
            if color[nid] == WHITE:
                dfs(nid)
        return issues

    def topological_order(self) -> list[str]:
        """Kahn's algorithm for topological sort."""
        nm = self._node_map()
        # in_degree[n] = number of n's dependencies that exist in the graph
        in_deg: dict[str, int] = {}
        for n in self.nodes:
            in_deg[n["id"]] = len([d for d in n.get("depends_on", []) if d in nm])
        queue: list[str] = [nid for nid, deg in in_deg.items() if deg == 0]
        order: list[str] = []
        while queue:
            nid = queue.pop(0)
            order.append(nid)
            # For each node that depends on nid, decrease its in-degree
            for n in self.nodes:
                if nid in n.get("depends_on", []):
                    in_deg[n["id"]] -= 1
                    if in_deg[n["id"]] == 0:
                        queue.append(n["id"])
        return order

    def progress_summary(self) -> dict[str, int]:
        counts: dict[str, int] = {"pending": 0, "in_progress": 0, "complete": 0, "failed": 0, "blocked": 0}
        for n in self.nodes:
            st = n.get("status", "pending")
            counts[st] = counts.get(st, 0) + 1
        return counts

    def depth_map(self) -> dict[str, int]:
        """Return the depth (longest path from a root) for each node."""
        nm = self._node_map()
        depths: dict[str, int] = {}

        def get_depth(nid: str) -> int:
            if nid in depths:
                return depths[nid]
            node = nm.get(nid)
            if not node or not node.get("depends_on"):
                depths[nid] = 0
                return 0
            d = max(get_depth(dep) for dep in node["depends_on"] if dep in nm) + 1
            depths[nid] = d
            return d

        for nid in nm:
            get_depth(nid)
        return depths


