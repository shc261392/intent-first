# ── cmd_spawn ─────────────────────────────────────────────────

def cmd_spawn(args: list[str]) -> None:
    """Create a child workflow linked to a parent.
    
    Usage: intent-first spawn <PARENT_ID> <NEW_NAME> [--intent "text"]
    """
    if len(args) < 2:
        print("Usage: intent-first spawn <PARENT_ID> <NEW_NAME> [--intent \"text\"]")
        sys.exit(1)

    parent_id = args[0]
    new_name = args[1]
    validate_workflow_id(parent_id)
    validate_workflow_id(new_name)

    # Parse optional --intent
    intent_text = ""
    i = 2
    while i < len(args):
        if args[i] == "--intent" and i + 1 < len(args):
            intent_text = args[i + 1]
            i += 2
        else:
            i += 1

    parent_dir = WORKFLOW_DIR / parent_id
    if not parent_dir.is_dir():
        print(f"\u274c Parent workflow not found: {parent_dir}")
        sys.exit(1)

    # Create the new workflow
    cmd_new([new_name])

    child_dir = WORKFLOW_DIR / new_name
    child_status = child_dir / "status.yml"

    # Set parent_workflow and spawned_from_stage on child
    _update_top_level_field(child_status, "parent_workflow", parent_id)
    _update_top_level_field(child_status, "spawned_from_stage", "artifacts")

    # Add to parent's spawned_workflows
    parent_status = parent_dir / "status.yml"
    _append_list_field(parent_status, "spawned_workflows", new_name)

    # Write intent if provided
    if intent_text:
        intent_file = child_dir / "s1_intent.md"
        intent_file.write_text(f"# Intent\n\n{intent_text}\n")
        info(f"Wrote intent to {intent_file}")

    print(f"\u2705 Spawned workflow '{new_name}' from parent '{parent_id}'")


