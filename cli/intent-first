def cmd_link(args: list[str]) -> None:
    """Link two workflows.
    
    Usage: intent-first link <ID1> <ID2> [--relation follows|blocks|related]
    """
    if len(args) < 2:
        print("Usage: intent-first link <ID1> <ID2> [--relation follows|blocks|related]")
        sys.exit(1)

    id1, id2 = args[0], args[1]
    validate_workflow_id(id1)
    validate_workflow_id(id2)

    relation = "related"
    i = 2
    while i < len(args):
        if args[i] == "--relation" and i + 1 < len(args):
            relation = args[i + 1]
            i += 2
        else:
            i += 1

    if relation not in ("follows", "blocks", "related"):
        print(f"\u274c Invalid relation: {relation}")
        print("   Valid: follows, blocks, related")
        sys.exit(1)

    for wid in (id1, id2):
