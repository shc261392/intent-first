# ── Workflow metadata helpers ─────────────────────────────────

def _read_top_level_field(status_file: Path, field: str) -> str:
    """Read a top-level field from status.yml (not inside stages block)."""
    if not status_file.is_file():
        return ""
    for line in status_file.read_text().splitlines():
        if line.startswith(f"{field}:"):
            return line.split(":", 1)[1].strip().strip('"').strip("'")
    return ""


def _update_top_level_field(status_file: Path, field: str, value: str) -> None:
    """Update or add a top-level field in status.yml."""
    if not status_file.is_file() or not os.access(status_file, os.W_OK):
        return
    lines = status_file.read_text().splitlines(keepends=True)
    found = False
    for i, line in enumerate(lines):
        if line.startswith(f"{field}:"):
            lines[i] = f'{field}: "{value}"\n'
            found = True
            break
    if not found:
        # Insert after workflow_id line
        for i, line in enumerate(lines):
            if line.startswith("workflow_id:"):
                lines.insert(i + 1, f'{field}: "{value}"\n')
                found = True
                break
        if not found:
            lines.append(f'{field}: "{value}"\n')
    fd, tmp = tempfile.mkstemp(dir=status_file.parent)
    try:
        with os.fdopen(fd, "w") as f:
            f.writelines(lines)
        Path(tmp).replace(status_file)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass


def _read_list_field(status_file: Path, field: str) -> list[str]:
    """Read a top-level list field (e.g., spawned_workflows: [...])."""
    raw = _read_top_level_field(status_file, field)
    if not raw or raw == "[]":
        return []
    # Simple parse: remove brackets, split by comma
    raw = raw.strip("[]")
    return [x.strip().strip('"').strip("'") for x in raw.split(",") if x.strip()]


def _append_list_field(status_file: Path, field: str, value: str) -> None:
    """Append a value to a top-level list field."""
    current = _read_list_field(status_file, field)
    if value not in current:
        current.append(value)
    serialized = "[" + ", ".join(f'"{v}"' for v in current) + "]"
    _update_top_level_field(status_file, field, serialized)


# ── Prompt / agent installer ─────────────────────────────────

def _install_to_dir(dir_path: Path, files: list[str], file_type: str) -> bool:
    """Download and install a list of files to a directory. Returns True if any file was installed."""
    dir_path.mkdir(parents=True, exist_ok=True)
    installed = False
    for fname in files:
        tmp_path = None
        try:
            fd, tmp = tempfile.mkstemp(dir=dir_path)
            os.close(fd)
            tmp_path = Path(tmp)
            if _download(f"{RAW}/{file_type}/{fname}", tmp_path):
                tmp_path.replace(dir_path / fname)
                tmp_path = None
                installed = True
        except Exception as exc:
            warn(f"Failed to install {file_type} {fname}: {exc}")
        finally:
            if tmp_path and tmp_path.exists():
                tmp_path.unlink()
    return installed


def _install_prompts_and_agents(tools: list[str]) -> bool:
    """Download latest prompts and agent files. Always installs to .github/ as fallback. Returns True if anything was installed."""
    installed_prompt_dirs: list[Path] = []
    installed_agent_dirs:  list[Path] = []
    
    # Install to detected tool directories
    for t in tools:
        dirs = _TOOL_DIRS.get(t)
        if not dirs:
            continue
        prompt_dir_str, agent_dir_str = dirs
        if prompt_dir_str:
            pd = Path(prompt_dir_str)
            if _install_to_dir(pd, INTENT_FIRST_PROMPTS, "prompts"):
                if pd not in installed_prompt_dirs:
                    installed_prompt_dirs.append(pd)
        if agent_dir_str:
            ad = Path(agent_dir_str)
            if _install_to_dir(ad, INTENT_FIRST_AGENTS, "agents"):
                if ad not in installed_agent_dirs:
                    installed_agent_dirs.append(ad)
    
    # ALWAYS ensure .github/ has the prompts (Copilot fallback), but not agents if not explicitly a Copilot project
    copilot_prompts = Path(".github/prompts")
    copilot_agents = Path(".github/agents")
    
    if copilot_prompts not in installed_prompt_dirs:
        if _install_to_dir(copilot_prompts, INTENT_FIRST_PROMPTS, "prompts"):
            installed_prompt_dirs.append(copilot_prompts)
    
    if "copilot" in tools and copilot_agents not in installed_agent_dirs:
        if _install_to_dir(copilot_agents, INTENT_FIRST_AGENTS, "agents"):
            installed_agent_dirs.append(copilot_agents)

    any_installed = len(installed_prompt_dirs) > 0 or len(installed_agent_dirs) > 0
    
    for pd in installed_prompt_dirs:
        info(f"Installed {len(INTENT_FIRST_PROMPTS)} prompts → {pd}/")
    for ad in installed_agent_dirs:
        info(f"Installed {len(INTENT_FIRST_AGENTS)} agents → {ad}/")
    
    if not any_installed:
        warn("Could not download prompts and agents. Check your internet connection.")
        return False
    
    return True


def _ask_tool_interactive() -> list[str]:
    """Ask interactively which AI tool the user uses when auto-detection finds nothing."""
    options = [
        ("1", "copilot",     "GitHub Copilot (VS Code)"),
        ("2", "cursor",      "Cursor"),
        ("3", "claude",      "Claude Code"),
        ("4", "windsurf",    "Windsurf"),
        ("5", "aider",       "Aider"),
        ("6", "cline",       "Cline / Roo"),
        ("7", None,          "None / skip"),
    ]
    print()
    print("  No AI tool configuration detected.")
    print("  Which AI coding tool do you use? (enter number(s), comma-separated)")
    print()
    for num, _, label in options:
        print(f"    {num}) {label}")
    print()
    try:
        if sys.stdin.isatty():
            sys.stdout.write("  Choice(s) [1]: ")
            sys.stdout.flush()
            reply = sys.stdin.readline().strip() or "1"
        else:
            with open("/dev/tty") as tty:
                sys.stdout.write("  Choice(s) [1]: ")
                sys.stdout.flush()
                reply = tty.readline().strip() or "1"
    except (EOFError, OSError):
        reply = "1"
    lookup = {num: name for num, name, _ in options if name}
    tools: list[str] = []
    for c in reply.replace(" ", "").split(","):
        name = lookup.get(c)
        if name:
            tools.append(name)
        elif c not in ("", "7"):
            warn(f"Unknown choice: {c} (skipped)")
    return tools


